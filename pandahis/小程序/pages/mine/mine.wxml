<view class="page-shell">
  <proto-nav title="我的" show-back="{{false}}"></proto-nav>

  <scroll-view scroll-y class="mine-scroll" style="padding-top: {{headerPadPx}}px;" enhanced show-scrollbar="{{false}}">

    <!-- 用户信息区 -->
    <view class="hero-section">
      <view class="hero-bg"></view>
      <view class="hero-content">
        <view class="avatar-wrap">
          <view class="avatar">{{avatarLetter}}</view>
          <view wx:if="{{isVip}}" class="vip-badge">VIP</view>
        </view>
        <view class="user-info">
          <text class="user-name">{{name}}</text>
          <text class="user-phone muted">{{phone}}</text>
        </view>
        <view class="edit-btn" bindtap="noop">
          <image class="edit-icon" src="/配图/icons/bianji.png" mode="aspectFit" />
        </view>
      </view>

      <!-- 统计数据 -->
      <view class="stats-row">
        <view class="stat-item" bindtap="goFootprint">
          <text class="stat-num accent">{{footprintCount}}</text>
          <text class="stat-label muted">足迹</text>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item" bindtap="goFavorite">
          <text class="stat-num accent">{{favoriteCount}}</text>
          <text class="stat-label muted">收藏</text>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item">
          <text class="stat-num accent">{{learnDays}}</text>
          <text class="stat-label muted">学习天</text>
        </view>
      </view>
    </view>

    <!-- 会员卡 -->
    <view wx:if="{{!isVip}}" class="vip-promo" bindtap="goVip">
      <view class="vip-promo-left">
        <image class="vip-promo-icon" src="/配图/icons/huiyuan.png" mode="aspectFit" />
        <view>
          <text class="vip-promo-title accent">开通年度会员</text>
          <text class="vip-promo-sub muted">全地域图谱 · 原文对照 · 跨文明评述</text>
        </view>
      </view>
      <text class="vip-promo-arrow muted">›</text>
    </view>

    <!-- 功能列表 -->
    <view class="list-section">
      <view class="list-row" bindtap="noop">
        <view class="list-icon-wrap share-bg">
          <image class="list-icon-img" src="/配图/icons/fenxiang.png" mode="aspectFit" />
        </view>
        <text class="list-label">分享给朋友</text>
        <text class="list-arrow muted">›</text>
      </view>
      <view class="row-divider"></view>
      <view class="list-row" bindtap="noop">
        <view class="list-icon-wrap gray-bg">
          <image class="list-icon-img" src="/配图/icons/shezhi.png" mode="aspectFit" />
        </view>
        <text class="list-label">设置</text>
        <text class="list-arrow muted">›</text>
      </view>
      <view class="row-divider"></view>
      <view class="list-row" bindtap="noop">
        <view class="list-icon-wrap gray-bg">
          <image class="list-icon-img" src="/配图/icons/bangzhuyufankui.png" mode="aspectFit" />
        </view>
        <text class="list-label">帮助与反馈</text>
        <text class="list-arrow muted">›</text>
      </view>
      <view class="row-divider"></view>
      <view class="list-row" bindtap="noop">
        <view class="list-icon-wrap gray-bg">
          <image class="list-icon-img" src="/配图/icons/guanyuwomen.png" mode="aspectFit" />
        </view>
        <text class="list-label">关于历史图谱</text>
        <text class="list-value muted">v1.0.0</text>
        <text class="list-arrow muted">›</text>
      </view>
    </view>

    <text class="logout muted" bindtap="goLogin">退出登录</text>
  </scroll-view>
</view>
