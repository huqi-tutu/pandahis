@import '../../styles/atlas.wxss';

.page-shell {
  min-height: 100vh;
  background: #F8F6F2;
}

.mine-scroll {
  height: 100vh;
  padding-bottom: 24rpx;
  box-sizing: border-box;
}

/* ─── Hero ─── */
.hero-section {
  position: relative;
  background: linear-gradient(145deg, rgba(155,62,56,0.12) 0%, #FAF7F3 60%);
  padding: 32rpx 32rpx 0;
  margin-bottom: 24rpx;
  overflow: hidden;
}

.hero-bg {
  position: absolute;
  top: -40rpx; right: -40rpx;
  width: 300rpx;
  height: 300rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(155,62,56,0.06) 0%, transparent 70%);
  pointer-events: none;
}

.hero-content {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 32rpx;
}

.avatar-wrap {
  position: relative;
  flex-shrink: 0;
}

.avatar {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #9B3E38, #C4764A);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  font-weight: 700;
  color: #FFFFFF;
  box-shadow: 0 4rpx 16rpx rgba(155, 62, 56, 0.3);
}

.vip-badge {
  position: absolute;
  bottom: 0; right: -4rpx;
  background: linear-gradient(135deg, #D6A84A, #F1A805);
  color: #fff;
  font-size: 16rpx;
  font-weight: 700;
  padding: 3rpx 10rpx;
  border-radius: 999rpx;
  letter-spacing: 1rpx;
}

.user-info {
  flex: 1;
}

.user-name {
  font-size: 40rpx;
  font-weight: 700;
  color: #262626;
  display: block;
  margin-bottom: 8rpx;
}

.user-phone { font-size: 24rpx; }

.edit-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(74, 63, 63, 0.07);
  display: flex;
  align-items: center;
  justify-content: center;
}

.edit-icon {
  width: 36rpx;
  height: 36rpx;
  opacity: 0.6;
}

.stats-row {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 24rpx 24rpx 0 0;
  padding: 28rpx 0;
  margin: 0 -32rpx;
  border-top: 1rpx solid #EDEAE6;
  margin-bottom: 0;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.stat-num {
  font-size: 44rpx;
  font-weight: 700;
  line-height: 1;
}

.stat-label { font-size: 22rpx; }

.stat-divider {
  width: 1rpx;
  height: 56rpx;
  background: #EDEAE6;
}

/* ─── 会员推广条 ─── */
.vip-promo {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 0 24rpx 24rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, rgba(155,62,56,0.06), rgba(214,168,74,0.06));
  border-radius: 20rpx;
  border: 1rpx solid rgba(155, 62, 56, 0.12);
}

.vip-promo-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.vip-promo-icon {
  width: 64rpx;
  height: 64rpx;
}

.vip-promo-title {
  font-size: 30rpx;
  font-weight: 700;
  display: block;
  margin-bottom: 6rpx;
}

.vip-promo-sub { font-size: 22rpx; }
.vip-promo-arrow { font-size: 40rpx; }

/* ─── 功能列表 ─── */
.list-section {
  margin: 0 24rpx 24rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  border: 1rpx solid #EDEAE6;
  overflow: hidden;
}

.list-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 28rpx 28rpx;
}

.list-icon-wrap {
  width: 68rpx;
  height: 68rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.accent-bg { background: rgba(155, 62, 56, 0.1); }
.warm-bg   { background: rgba(214, 168, 74, 0.1); }
.share-bg  { background: rgba(91, 141, 239, 0.1); }
.gray-bg   { background: rgba(74, 63, 63, 0.07); }

.list-icon-img {
  width: 40rpx;
  height: 40rpx;
}

.list-label {
  flex: 1;
  font-size: 30rpx;
  color: #262626;
}

.list-value { font-size: 24rpx; }
.list-arrow { font-size: 32rpx; }

.row-divider {
  height: 1rpx;
  background: #EDEAE6;
  margin: 0 28rpx;
}

/* ─── 退出按钮 ─── */
.logout {
  display: block;
  text-align: center;
  padding: 32rpx;
  font-size: 26rpx;
  letter-spacing: 4rpx;
}
