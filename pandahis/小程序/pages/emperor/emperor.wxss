/* pages/emperor/emperor.wxss */
.container {
  padding: 30rpx;
}

.header {
  text-align: center;
  margin-bottom: 40rpx;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #2c3e50;
  display: block;
}

.subtitle {
  font-size: 28rpx;
  color: #7f8c8d;
  margin-top: 10rpx;
  display: block;
}

.loading, .empty {
  text-align: center;
  padding: 60rpx;
  color: #7f8c8d;
}

.emperor-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.emperor-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.emperor-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.emperor-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #2c3e50;
}

.emperor-reign {
  font-size: 24rpx;
  color: #3498db;
  background: #ecf0f1;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.emperor-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 10rpx;
}

.emperor-reign {
  font-size: 24rpx;
  color: #7f8c8d;
}

.emperor-tags {
  display: flex;
  gap: 10rpx;
  flex-wrap: wrap;
}

.tag {
  font-size: 22rpx;
  color: #3498db;
  background: #ecf0f1;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
}

.emperor-dynasty {
  font-size: 24rpx;
  color: #3498db;
  background: #ecf0f1;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}
