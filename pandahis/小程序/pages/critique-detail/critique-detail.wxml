<view class="proto-shell">
  <proto-nav title="评述详情" show-back="{{true}}"></proto-nav>

  <view class="detail-body pad" style="padding-top: {{headerPadPx}}px;">
    <view wx:if="{{title}}" class="crit-detail-title">{{title}}</view>
    <view class="meta card-paper">
      <view class="row"><text class="lab muted">评述人</text><text class="val">{{author}}</text></view>
      <view class="row"><text class="lab muted">评述著作</text><text class="val">{{book}}</text></view>
      <view class="row"><text class="lab muted">评述时代</text><text class="val">{{era}}</text></view>
    </view>
    <text class="sec accent">评述内容</text>
    <view class="text-card card-paper">{{body}}</view>
  </view>
</view>
