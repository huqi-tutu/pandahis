@import '../../styles/atlas.wxss';
@import '../mine-footprint/mine-footprint.wxss';

.tabs {
  display: flex;
  gap: 12rpx;
  margin-bottom: 24rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 8rpx;
  border: 1rpx solid #EDEAE6;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 16rpx;
  border-radius: 10rpx;
  font-size: 26rpx;
  color: #9A9A9A;
}

.tab.on {
  font-weight: 600;
  color: #FFFFFF;
  background: #4A3F3F;
}
