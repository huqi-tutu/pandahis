@import '../../styles/atlas.wxss';

.page-shell {
  background: #F8F6F2;
  min-height: 100vh;
}

.vip-invite-body {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  overflow: hidden;
}

.vip-invite-sheet {
  padding: 32rpx 32rpx 48rpx;
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

/* ─────────────────────────────────────
   会员卡：PNG 圆角透明区透出页面底，卡片浮起
───────────────────────────────────── */
.vip-inv-card {
  position: relative;
  background: transparent;
  overflow: visible;
}

.vip-inv-card-bg {
  width: 100%;
  display: block;
  vertical-align: top;
  background-color: transparent;
  /* 阴影跟随 PNG 不透明区域（圆角卡片轮廓） */
  filter: drop-shadow(0 8rpx 24rpx rgba(140, 100, 50, 0.2));
}

.vip-inv-card-overlay {
  position: absolute;
  left: 0;
  width: 68%;
  /* 对齐素材圆角留白（约 18% 高度） */
  top: 18%;
  bottom: 18%;
  padding: 0 28rpx 0 32rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 8rpx;
  pointer-events: none;
}

.vip-inv-card-overlay .vip-inv-chip {
  pointer-events: auto;
}

.vip-inv-card-head {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 4rpx;
}

.vip-inv-card-title {
  font-family: 'Noto Serif SC', 'Songti SC', serif;
  font-size: 30rpx;
  font-weight: 700;
  color: #5C4420;
  letter-spacing: 1rpx;
  line-height: 1.35;
  width: 100%;
}

.vip-inv-chip {
  font-family: 'PingFang SC', -apple-system, sans-serif;
  font-size: 20rpx;
  font-weight: 600;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.58);
  color: #7A6240;
  border: 1rpx solid rgba(184, 150, 90, 0.32);
  letter-spacing: 0.5rpx;
}

.vip-inv-chip--ok {
  background: rgba(255, 255, 255, 0.72);
  color: #3D6B4A;
  border-color: rgba(72, 140, 96, 0.28);
}

.vip-inv-card-line {
  font-family: 'PingFang SC', -apple-system, sans-serif;
  font-size: 22rpx;
  font-weight: 400;
  color: rgba(92, 68, 32, 0.78);
  letter-spacing: 0.5rpx;
  line-height: 1.55;
  display: block;
}

.vip-inv-card-line--sub {
  margin-top: 2rpx;
  font-size: 20rpx;
  color: rgba(92, 68, 32, 0.62);
}

/* ─────────────────────────────────────
   文字区
───────────────────────────────────── */
.vip-invite-rule-lead {
  font-family: 'PingFang SC', -apple-system, sans-serif;
  font-size: 24rpx;
  line-height: 1.65;
  color: #6A6A6A;
  letter-spacing: 0.3rpx;
}

.vip-inv-strong {
  font-family: 'PingFang SC', -apple-system, sans-serif;
  font-size: 24rpx;
  font-weight: 600;
  color: #262626;
}

.vip-invite-complete-sub {
  font-family: 'PingFang SC', -apple-system, sans-serif;
  font-size: 22rpx;
  color: #8A8A8A;
  margin-top: -20rpx;
  letter-spacing: 0.3rpx;
}

.vip-invite-progress {
  font-family: 'PingFang SC', -apple-system, sans-serif;
  font-size: 22rpx;
  color: #8A8A8A;
  letter-spacing: 0.5rpx;
}

/* ─────────────────────────────────────
   助力槽
───────────────────────────────────── */
.vip-invite-slots {
  display: flex;
  flex-direction: row;
  justify-content: space-around;
}

.vip-inv-slot {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.vip-inv-slot-ring {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  border: 2rpx dashed #E0DEDC;
  background: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
}

.vip-inv-slot--filled .vip-inv-slot-ring {
  border: 2rpx solid rgba(74, 63, 63, 0.25);
  background: rgba(74, 63, 63, 0.06);
}

.vip-inv-slot-avatar {
  font-family: 'PingFang SC', -apple-system, sans-serif;
  font-size: 28rpx;
  font-weight: 600;
  color: #4A3F3F;
}

.vip-inv-slot-plus {
  width: 28rpx;
  height: 28rpx;
  position: relative;
}

.vip-inv-slot-plus::before,
.vip-inv-slot-plus::after {
  content: '';
  position: absolute;
  background: #E0DEDC;
  border-radius: 2rpx;
}

.vip-inv-slot-plus::before {
  width: 28rpx; height: 2rpx;
  top: 50%; left: 0;
  transform: translateY(-50%);
}

.vip-inv-slot-plus::after {
  width: 2rpx; height: 28rpx;
  left: 50%; top: 0;
  transform: translateX(-50%);
}

.vip-inv-slot-txt {
  font-family: 'PingFang SC', -apple-system, sans-serif;
  font-size: 20rpx;
  color: #8A8A8A;
  letter-spacing: 0.5rpx;
}

.vip-inv-slot--filled .vip-inv-slot-txt {
  color: #4A3F3F;
  font-weight: 500;
}

/* ─────────────────────────────────────
   CTA
───────────────────────────────────── */
.vip-invite-cta {
  margin-top: 8rpx;
  height: 88rpx;
  border-radius: 12rpx;
  background: #4A3F3F;
  color: #FFFFFF;
  font-family: 'PingFang SC', -apple-system, sans-serif;
  font-size: 28rpx;
  font-weight: 600;
  letter-spacing: 3rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(74, 63, 63, 0.22);
}

.vip-demo-tip {
  text-align: center;
  font-family: 'PingFang SC', -apple-system, sans-serif;
  font-size: 20rpx;
  color: #B0A89E;
  margin-top: -12rpx;
}
