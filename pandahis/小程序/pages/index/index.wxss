/* pages/index/index.wxss — 历史图谱 · 时间轴固定 + 文明列横滑 */

/* ══════════════════════════════════════════════
   动画
══════════════════════════════════════════════ */
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(20rpx); }
  to   { opacity: 1; transform: translateY(0); }
}
@keyframes blink {
  0%, 80%, 100% { opacity: 0.15; transform: scale(0.7); }
  40%           { opacity: 1;    transform: scale(1); }
}

/* ══════════════════════════════════════════════
   全局
══════════════════════════════════════════════ */
page {
  background: #0C0C10;
  color: #E0E0EC;
  font-family: -apple-system, 'PingFang SC', sans-serif;
}

.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #0C0C10;
  overflow: hidden;
}

/* ══════════════════════════════════════════════
   主区域：左（时间轴）+ 右（文明列）
══════════════════════════════════════════════ */
.main-row {
  flex: 1;
  display: flex;
  flex-direction: row;
  overflow: hidden;
  /* 为底部固定导航留底部空间 */
  padding-bottom: env(safe-area-inset-bottom);
}

/* ══════════════════════════════════════════════
   左：固定时间轴面板
══════════════════════════════════════════════ */
.time-panel {
  width: 88rpx;
  min-width: 88rpx;
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  background: #0C0C10;
  border-right: 1rpx solid rgba(200, 195, 180, 0.08);
  z-index: 10;
}

/* 时间列标题头 */
.time-panel-hd {
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 17rpx;
  color: rgba(200, 195, 180, 0.3);
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.07);
  flex-shrink: 0;
  background: rgba(10, 10, 16, 0.98);
}

/* 时间列纵向滚动容器 */
.time-panel-sc {
  flex: 1;
  height: 0; /* WeChat flex scroll-view 惯用写法 */
}

/* 时间刻度列表容器，顶部与卡片列表保持一致 */
.time-cells-wrap {
  padding-top: 0;
}

/* 底部留白：与 cards-wrap 对齐，确保能滚到底 */
.time-bottom-pad {
  height: 120rpx;
}

/* 单个时间刻度格：与对应 civ-row 等高，内容上下左右居中 */
.time-cell {
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

/* 刻度行：─ 年份 ─ 同行 */
.time-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  width: 100%;
}

/* 左右刻度横线，等长 */
.tick-h {
  width: 10rpx;
  height: 1rpx;
  background: rgba(200, 195, 180, 0.28);
  flex-shrink: 0;
}

/* 年份文字：居中，字符间距适中 */
.year-label {
  flex: 1;
  font-size: 17rpx;
  color: rgba(200, 195, 180, 0.40);
  font-variant-numeric: tabular-nums;
  text-align: center;
  line-height: 1.3;
  letter-spacing: 0.5rpx;
  word-break: keep-all;
}

/* ══════════════════════════════════════════════
   右：文明列横向滚动容器
══════════════════════════════════════════════ */
.civ-h-scroll {
  flex: 1;
  overflow: hidden;
}

/* 文明列宽内容：5列 × 220rpx = 1100rpx，超出触发横滑 */
.civ-wide {
  width: 1100rpx;
  height: 100%;
  display: flex;
  flex-direction: column;
}

/* ══════════════════════════════════════════════
   文明列标题行（高度与 time-panel-hd 精确匹配）
══════════════════════════════════════════════ */
.civ-header {
  height: 52rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  flex-shrink: 0;
  background: rgba(10, 10, 16, 0.98);
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.07);
}

.col-h {
  flex: 1;
  font-size: 19rpx;
  font-weight: 600;
  text-align: center;
  letter-spacing: 0.5rpx;
}

.china-h    { color: #D45050; }
.asia-h     { color: #D4882A; }
.europe-h   { color: #4A80D0; }
.americas-h { color: #3A9A60; }
.africa-h   { color: #B875D5; }

/* ══════════════════════════════════════════════
   文明数据纵向滚动
══════════════════════════════════════════════ */
.civ-v-scroll {
  flex: 1;
  height: 0; /* WeChat flex scroll-view 惯用写法 */
}

.cards-wrap {
  padding: 0 0 120rpx;
  animation: fadeUp 0.5s ease both;
}

/* ══════════════════════════════════════════════
   文明数据行（等高对应 time-cell）
══════════════════════════════════════════════ */
.civ-row {
  display: flex;
  flex-direction: row;
  align-items: stretch;
  border-radius: 8rpx;
  margin-bottom: 4rpx;
  overflow: hidden;
}

/* ══════════════════════════════════════════════
   数据列通用
══════════════════════════════════════════════ */
.col-data {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: stretch;
  padding: 5rpx 4rpx;
  overflow: hidden;
  min-width: 0;
}

/* ══════════════════════════════════════════════
   ① 中华文明：毛玻璃英雄卡
══════════════════════════════════════════════ */
.col-china {
  padding: 4rpx 5rpx 4rpx 3rpx;
}

.chip-china {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  gap: 5rpx;
  padding: 10rpx 11rpx;
  border-radius: 8rpx;
  backdrop-filter: blur(14rpx);
  -webkit-backdrop-filter: blur(14rpx);
  background: rgba(255, 255, 255, 0.035);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.06),
              0 2rpx 12rpx rgba(0, 0, 0, 0.15);
}

.chip-title {
  font-size: 20rpx;
  font-weight: 600;
  line-height: 1.45;
  word-break: break-all;
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  letter-spacing: 0.3rpx;
  opacity: 0.92;
}

.chip-reign {
  font-size: 15rpx;
  color: rgba(200, 195, 180, 0.32);
  line-height: 1;
  letter-spacing: 0.5rpx;
}

/* ══════════════════════════════════════════════
   ②③④⑤ 其他文明：色块（无左竖线，背景内联）
══════════════════════════════════════════════ */
.chip-ext {
  border-radius: 6rpx;
  padding: 8rpx 7rpx;
}

.chip-ext-name {
  font-size: 16rpx;
  font-weight: 500;
  line-height: 1.45;
  word-break: break-all;
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 4;
  -webkit-box-orient: vertical;
}

.asia-name     { color: #D4882A; }
.europe-name   { color: #6A9EE0; }
.americas-name { color: #50A870; }
.africa-name   { color: #B875D5; }

/* ══════════════════════════════════════════════
   加载动画
══════════════════════════════════════════════ */
.loading-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
  height: 400rpx;
}
.loading-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: rgba(200, 170, 60, 0.5);
  animation: blink 1.2s infinite ease-in-out;
}
.loading-dot-2 { animation-delay: 0.2s; }
.loading-dot-3 { animation-delay: 0.4s; }

/* ══════════════════════════════════════════════
   时间轴末端
══════════════════════════════════════════════ */
.timeline-end {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0 28rpx;
  gap: 12rpx;
}
.end-line {
  width: 1rpx;
  height: 48rpx;
  background: linear-gradient(to bottom, rgba(200, 170, 60, 0.4), transparent);
}
.end-text {
  font-size: 28rpx;
  font-weight: 700;
  color: rgba(210, 185, 100, 0.5);
  letter-spacing: 4rpx;
}
.end-sub {
  font-size: 19rpx;
  color: rgba(200, 195, 180, 0.2);
  letter-spacing: 1rpx;
}

/* ══════════════════════════════════════════════
   底部导航
══════════════════════════════════════════════ */
.bottom-nav {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  background: rgba(10, 10, 14, 0.97);
  border-top: 1rpx solid rgba(255, 255, 255, 0.055);
  padding: 12rpx 0 env(safe-area-inset-bottom);
  z-index: 100;
  backdrop-filter: blur(24rpx);
  -webkit-backdrop-filter: blur(24rpx);
}

.nav-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 5rpx;
  padding: 6rpx 0;
  color: rgba(200, 195, 180, 0.25);
}
.nav-item.active { color: #D4AA20; }
.nav-icon  { font-size: 30rpx; }
.nav-label { font-size: 17rpx; letter-spacing: 1rpx; }
