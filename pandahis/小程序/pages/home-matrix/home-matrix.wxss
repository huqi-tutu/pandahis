@import '../../styles/atlas.wxss';

/* ─── 页面容器 ─── */
.page-shell {
  background: #FFFFFF;
  min-height: 100vh;
}

.matrix-data-loading {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 48rpx;
  z-index: 200;
  display: flex;
  justify-content: center;
  pointer-events: none;
}

.matrix-data-loading__inner {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 24rpx;
  border-radius: 12rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.matrix-data-loading__dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #2A7A5D;
  animation: matrix-loading-pulse 1.2s ease-in-out infinite;
}

.matrix-data-loading__text {
  font-size: 24rpx;
  color: #6C757D;
  line-height: 1.6;
}

@keyframes matrix-loading-pulse {
  0%, 100% { opacity: 0.35; transform: scale(0.92); }
  50% { opacity: 1; transform: scale(1); }
}

/* ─── 全部文明浮层 ─── */
.civ-picker {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 500;
  display: flex;
  flex-direction: column;
  pointer-events: auto;
}

.civ-picker-sheet {
  flex-shrink: 0;
  background: #FFFFFF;
  border-radius: 0 0 24rpx 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(47, 41, 38, 0.08);
  overflow: hidden;
  box-sizing: border-box;
}

.civ-picker-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  column-gap: 16rpx;
  row-gap: 16rpx;
  padding: 24rpx;
  box-sizing: border-box;
  height: 100%;
  justify-items: center;
  align-content: start;
}

.civ-picker-item {
  width: 100%;
  display: flex;
  justify-content: center;
  align-items: center;
  box-sizing: border-box;
}

.civ-picker-card {
  border-radius: 8rpx;
  overflow: hidden;
  border: 2rpx solid transparent;
  box-sizing: border-box;
  background: #F8F6F2;
  transition: border-color 0.2s ease;
}

.civ-picker-item--active .civ-picker-card {
  border-color: #2A7A5D;
}

.civ-picker-card-img {
  width: 100%;
  height: 100%;
  display: block;
}

.civ-picker-backdrop {
  flex: 1;
  min-height: 0;
  background: rgba(47, 41, 38, 0.28);
}

/* ══════════════════════════════════════════════════════════════════
   【新版】层叠卡片 Tab 样式
   ══════════════════════════════════════════════════════════════════ */

/* 统一 Tab 区域容器：height 由 JS inline style 实时注入，此处不设固定高度 */
.civ-tab-area {
  position: fixed;
  left: 0; right: 0;
  z-index: 100;
  background: rgba(255, 255, 255, 0.97);
  border-bottom: 1rpx solid #EDEAE6;
  overflow: hidden;
}

/* 图片层叠层：铺满容器（滚动渐隐由 WXS 直驱，不加 transition） */
.civ-stack-layer {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  display: flex;
  align-items: center;
  transform: translate3d(0, 0, 0);
}

/* 内层相对定位容器：铺满 Tab 区，卡片在区内垂直居中 */
.civ-stack-container {
  position: relative;
  width: 100%;
  height: 100%;
  transform: translate3d(0, 0, 0);
}

/* 每张卡片：GPU 合成层 + 丝滑缓动 */
.civ-stack-card {
  position: absolute;
  top: 50%;
  margin-top: -59rpx; /* 118rpx 高度的一半，严格上下居中 */
  width: 104rpx;
  height: 118rpx;
  border-radius: 8rpx;
  overflow: hidden;
  transform-origin: 50% 50%;
  backface-visibility: hidden;
  -webkit-backface-visibility: hidden;
  transition:
    transform 0.34s cubic-bezier(0.22, 1, 0.36, 1),
    opacity   0.32s cubic-bezier(0.22, 1, 0.36, 1);
}

.civ-stack-card--moving {
  will-change: transform, opacity;
}

.civ-stack-img {
  width: 100%;
  height: 100%;
  display: block;
}

/* ── 文字 Tab 层（滚动渐现由 WXS 直驱） ── */
.civ-text-layer {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  display: flex;
  align-items: center;
  transform: translate3d(0, 0, 0);
}

.civ-text-scroll {
  width: 100%;
  /* 高度随内容自适应，不写死 */
  white-space: nowrap;
  overflow: hidden;
}

.civ-text-inner {
  display: inline-flex;
  flex-direction: row;
  align-items: center;
  padding: 0 28rpx;
  gap: 10rpx;
  box-sizing: content-box;
}

.civ-text-item {
  flex-shrink: 0;
  /* 不设固定高度，由 padding + line-height 撑开 */
  padding: 10rpx 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 26rpx;
  font-size: 26rpx;
  font-weight: 400;
  color: #7A7570;
  letter-spacing: 1rpx;
  transition: color 0.18s ease, background 0.18s ease;
  white-space: nowrap;
}

.civ-text-item--active {
  color: #1A1816;
  font-weight: 600;
  background: rgba(42, 42, 42, 0.10);
}

/* ══════════════════════════════════════════════════════════════════
   【旧版】横向滑动 Tab 样式（保留，供 stackMode=false 时使用）
   ══════════════════════════════════════════════════════════════════ */

/* ─── 文明 Tab 栏（图片卡片）─── */
.civ-rail-wrap {
  position: fixed;
  left: 0; right: 0;
  z-index: 100;
  height: 180rpx;
  background: rgba(255, 255, 255, 0.97);
  border-bottom: 1rpx solid #EDEAE6;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.civ-rail-scroll {
  width: 100%;
  height: 100%;
  /* inline-flex 子元素需要阻止父级换行 */
  white-space: nowrap;
  overflow: hidden;
}

.civ-rail-inner {
  /* inline-flex：容器宽度由内容撑开，scroll-view 能正确追踪总宽度 */
  display: inline-flex;
  flex-direction: row;
  align-items: center;
  min-height: 100%;
  /* gap 与 JS 侧必须保持一致：CIV_CARD_GAP_RPX = 16 */
  gap: 16rpx;
  /* 不设水平 padding，彻底消除 padL 对 scroll-left 坐标的影响 */
  padding: 0;
  box-sizing: border-box;
}

/* 每个文明卡片 ── 宽 130rpx，图高 152rpx，无文字行 */
/* scale / opacity 由 JS 按距离计算后写入 inline style */
.civ-card {
  flex-shrink: 0;
  width: 130rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  border-radius: 12rpx;
  overflow: hidden;
  background: transparent;           /* 去掉多余背景 */
  position: relative;
  transform-origin: center center;
  /* 弹性弹出曲线：selected 时 scale 有轻微过冲，更优雅 */
  transition: transform 0.38s cubic-bezier(0.34, 1.56, 0.64, 1),
              opacity   0.30s ease-out;
}

.civ-card-img-wrap {
  width: 130rpx;
  height: 152rpx;
  overflow: hidden;
}

.civ-card-img {
  width: 100%;
  height: 100%;
  display: block;
}

/* ─── 矩阵滚动区（统一页面底色，与色块六色无关） ─── */
.matrix-scroll {
  position: fixed;
  left: 0;
  right: 0;
  z-index: 50;
  box-sizing: border-box;
  background: #FFFFFF;
}

/* 矩阵整体：相对定位容器，高度由 JS 注入 */
.matrix-body {
  position: relative;
  width: 100%;
  box-sizing: border-box;
  background: #FFFFFF;
  overflow: visible;
}

/* 左：时间刻度列 */
.matrix-time-col {
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 84rpx;
  border-right: 1rpx solid #EDEAE6;
  background: #FFFFFF;
  z-index: 2;
  box-sizing: border-box;
  padding-left: 8rpx;
  padding-right: 4rpx;
}

.time-row-abs {
  position: absolute;
  left: 0;
  right: 0;
  display: flex;
  flex-direction: column;
  align-items: stretch;
  justify-content: flex-start;
  padding: 12rpx 0 0;
  box-sizing: border-box;
  overflow: visible;
}

.time-row-abs--compact {
  padding-top: 0;
}

/* 右：卡片画布 */
.matrix-canvas {
  position: absolute;
  left: 84rpx;
  right: 0;
  top: 0;
  bottom: 0;
  background: #FFFFFF;
  overflow: visible;
}

/* 内层：色块与标签参照区，左/上/右留呼吸间距（右 20rpx ≈ 10px） */
.matrix-canvas-inner {
  position: absolute;
  left: 12rpx;
  right: 20rpx;
  top: 12rpx;
  bottom: 8rpx;
  background: #FFFFFF;
  overflow: visible;
}

/* ─── 政权块（绝对定位，可多段拼接成不规则形） ─── */
.era-block {
  position: absolute;
  box-sizing: border-box;
  border: none;
  overflow: hidden;
  z-index: 1;
}

.era-block-fill {
  position: absolute;
  /* 微扩填充，消除百分比定位与圆角抗锯齿接缝 */
  left: -2rpx;
  right: -2rpx;
  top: -2rpx;
  bottom: -2rpx;
  z-index: 0;
  pointer-events: none;
  opacity: 0.85;
  transition: opacity 0.2s ease;
}

.era-block--hover .era-block-fill {
  opacity: 0.73;
}

/* 指定 L 形 / 多段色块：仅填充层不透明 + 微扩，消段间接缝，不改色块几何 */
.era-block-fill--solid-seam {
  opacity: 1;
  top: -4rpx;
  bottom: -4rpx;
  left: -3rpx;
  right: -3rpx;
}

/* 与邻块留 16rpx 的边：该侧不微扩，避免吃掉间距 */
.era-block-fill--solid-seam.era-block-fill--gap-top { top: 0; }
.era-block-fill--solid-seam.era-block-fill--gap-bottom { bottom: 0; }
.era-block-fill--solid-seam.era-block-fill--gap-left { left: 0; }
.era-block-fill--solid-seam.era-block-fill--gap-right { right: 0; }

.era-block--hover .era-block-fill--solid-seam {
  opacity: 0.88;
}

/* 黄帝色块：极弱纸感噪点（预览，仅 zhong_hua_wu_di_huang_di） */
.era-block-paper-grain {
  position: absolute;
  left: -2rpx;
  right: -2rpx;
  top: -2rpx;
  bottom: -2rpx;
  z-index: 1;
  pointer-events: none;
  overflow: hidden;
  background-image: url('/images/paper-grain-huangdi.png');
  background-repeat: repeat;
  background-size: 96rpx 61rpx;
  opacity: 0.22;
  mix-blend-mode: soft-light;
}

.era-block--hover .era-block-paper-grain {
  opacity: 0.18;
}

/* 统一标签层：左上名称 + 时间（已去掉左侧色条与色块描边） */
.entry-chrome {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  pointer-events: none;
  z-index: 3;
  overflow: visible;
}

.entry-header-wrap {
  position: absolute;
  box-sizing: border-box;
  padding: 8rpx 8rpx 8rpx 10rpx;
  overflow: visible;
}

/* 时间锚定层：对齐对应色块段，贴底角 */
.entry-time-wrap {
  position: absolute;
  box-sizing: border-box;
  pointer-events: none;
  overflow: visible;
  z-index: 2;
}

.card-time-range--br,
.card-time-range--bl {
  position: absolute;
  bottom: 8rpx;
  z-index: 2;
  font-family: 'SF Mono', 'Menlo', monospace;
  font-size: 16rpx;
  font-weight: 400;
  line-height: 1.35;
  color: #B0A89E;
  letter-spacing: 0;
  white-space: nowrap;
  overflow: visible;
  text-shadow: none;
}

.card-time-range--br {
  right: 10rpx;
  text-align: right;
}

.card-time-range--bl {
  left: 8rpx;
  text-align: left;
}

.entry-header {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 6rpx;
  width: 100%;
  padding-top: 0;
  box-sizing: border-box;
}

/* 同时期政权 = 1：名称 + 标签横排，标签在右、垂直居中 */
.entry-header--inline {
  flex-direction: row;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
}

/* 同时期政权 > 1：名称在上，标签在下左对齐 */
.entry-header--stacked {
  flex-direction: column;
  align-items: flex-start;
  gap: 6rpx;
}

/* 胶囊标签（无边框） */
.entry-tag-row {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  align-items: center;
  gap: 6rpx;
  max-width: 100%;
}

.entry-tag-row--inline {
  flex-wrap: nowrap;
  flex-shrink: 1;
  min-width: 0;
}

.entry-tag-col {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 4rpx;
  max-width: 100%;
}

.entry-tag {
  display: inline-block;
  vertical-align: top;
  max-width: 100%;
  padding: 3rpx 10rpx;
  border-radius: 20rpx;
  font-size: 15rpx;
  font-weight: 500;
  line-height: 1.35;
  color: #FFFFFF;
  white-space: nowrap;
  box-sizing: border-box;
}

.entry-tag--stack {
  white-space: normal;
  word-break: break-all;
  align-self: flex-start;
}

.card-person--inline {
  font-size: 22rpx;
  line-height: 1.25;
  flex-shrink: 0;
  max-width: 100%;
  word-break: break-all;
}

.card-person--stacked {
  font-size: 20rpx;
  line-height: 1.25;
  max-width: 100%;
  word-break: break-all;
}

.entry-header--stacked .entry-tag {
  font-size: 14rpx;
  padding: 2rpx 8rpx;
}

.entry-header-left {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 2rpx;
  align-items: flex-start;
}

.card-time-range--tr {
  flex-shrink: 0;
  text-align: right;
  max-width: 46%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 保留旧行布局类（兼容） */
.matrix-row {
  display: flex;
  flex-direction: row;
  align-items: stretch;
  flex-shrink: 0;
  overflow: hidden;
  box-sizing: border-box;
}

.matrix-row--ref {
  opacity: 0.7;
}

.card-area--ref {
  flex: 1;
  min-width: 0;
}

.time-cell {
  width: 84rpx;
  flex-shrink: 0;
  border-right: 1rpx solid #EDEAE6;
  display: flex;
  flex-direction: column;
  align-items: stretch;
  justify-content: flex-start;
  padding: 12rpx 0 0;
  box-sizing: border-box;
  background: rgba(255, 255, 255, 0.90);
}

.time-label-wrap {
  display: flex;
  flex-direction: column;
  align-items: stretch;
  gap: 5rpx;
  width: 100%;
}

/* 年份行：左右各一短刻度，分别贴左缘与时间轴竖线 */
.time-year-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  padding: 0;
  box-sizing: border-box;
}

.time-h-line--edge {
  flex-shrink: 0;
  width: 10rpx;
  height: 1rpx;
  background: rgba(160, 152, 142, 0.32);
}

.time-year {
  flex: 1;
  flex-shrink: 1;
  min-width: 0;
  padding: 0 2rpx;
  font-family: 'SF Mono', 'Menlo', monospace;
  font-size: 14rpx;
  font-weight: 500;
  font-variant-numeric: tabular-nums;
  color: #B0A89E;
  text-align: center;
  letter-spacing: 2rpx;
  line-height: 1.25;
  white-space: nowrap;
}

/* ─── 华夏参考标注区（朝代名 + 展开箭头）─── */
.time-hx-wrap {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: 3rpx;
  width: 100%;
  padding: 0 2rpx;
  box-sizing: border-box;
}

.time-hx-wrap--tap {
  min-height: 40rpx;
  padding: 4rpx 2rpx;
  box-sizing: border-box;
}

/* 华夏朝代名（字号由 JS 按列宽自适应） */
.time-dynasty {
  font-size: 16rpx;
  color: #B0A89E;
  text-align: center;
  letter-spacing: 0;
  line-height: 1.3;
  white-space: nowrap;
  flex-shrink: 1;
  min-width: 0;
  max-width: 100%;
}

/* 展开/收起箭头（仅华夏文明下显示） */
.time-expand-arrow {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 2rpx;
}

.time-arrow-icon {
  font-size: 14rpx;
  color: #9A9090;
  line-height: 1;
}

/* ─── 右：卡片区域（flex 横向，支持并列多卡）─── */
.card-area {
  flex: 1;
  min-width: 0;
  padding: 6rpx 12rpx 6rpx 10rpx;
  box-sizing: border-box;
  display: flex;
  align-items: stretch;
  gap: 6rpx;    /* 并列卡片间距 */
}

.slot-wrap {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: stretch;
}

/* 空占位槽：同朝代组内未建立/已覆灭的政权，保留均分位置 */
.slot-empty {
  flex: 1;
  min-width: 0;
}


/* ─── 大卡（单列） ─── */
.era-card {
  flex: 1;
  width: 100%;
  border-radius: 10rpx;
  background: transparent;
  border: 1rpx solid #EDEAE6;
  position: relative;
  overflow: hidden;
  box-sizing: border-box;
}

.era-card--hover { opacity: 0.78; }

/* 左侧彩色短竖条：内嵌圆角胶囊形 */
.card-left-bar {
  position: absolute;
  left: 0;
  top: 10rpx;
  bottom: 10rpx;
  width: 7rpx;
  border-radius: 999rpx;
  transform: translateX(2rpx);
  z-index: 2;
}

.era-block .card-top-left {
  left: 12rpx;
  right: 8rpx;
  z-index: 3;
}

.mini-bar {
  top: 6rpx;
  bottom: 6rpx;
}

/* 左上角：名称 + 朝代（无头像） */
.card-top-left {
  position: absolute;
  top: 10rpx;
  left: 14rpx;
  right: 8rpx;
  display: flex;
  flex-direction: row;
  align-items: flex-start;
}

.card-text-block {
  display: flex;
  flex-direction: column;
  gap: 2rpx;
  align-items: flex-start;
  min-width: 0;
}

/* 帝王名（大卡/小卡统一） */
.card-person,
.mini-person {
  font-family: 'Noto Serif SC', 'Songti SC', serif;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.3;
  color: #4A3F3F;
  letter-spacing: 0.5rpx;
  max-width: 100%;
}

/* 朝代名（大卡/小卡统一） */
.card-dynasty-name,
.mini-dynasty-name {
  font-family: 'PingFang SC', -apple-system, sans-serif;
  font-size: 18rpx;
  font-weight: 400;
  line-height: 1.35;
  color: #8A8A8A;
  overflow: hidden;
}

/* 起止 / 即位—退位 时间 */
.card-time-range {
  font-family: 'SF Mono', 'Menlo', monospace;
  font-size: 16rpx;
  font-weight: 400;
  line-height: 1.35;
  color: #B0A89E;
  letter-spacing: -0.3rpx;
  display: inline-block;
  text-shadow: none;
}

/* 矩阵标签层：时间完整显示 */
.entry-chrome .entry-header-wrap {
  overflow: visible;
}

.entry-chrome .entry-time-wrap {
  overflow: visible;
}

.entry-chrome .card-person,
.entry-chrome .card-person--inline,
.entry-chrome .card-person--stacked {
  color: #4A3F3F;
  text-shadow: none;
}

.entry-chrome .card-time-range--br,
.entry-chrome .card-time-range--bl {
  overflow: visible;
  white-space: nowrap;
  color: #B0A89E;
  text-shadow: none;
}

/* 在位时长（小卡等遗留） */
.card-tenure-br,
.mini-tenure-br {
  position: absolute;
  bottom: 7rpx;
  right: 8rpx;
  font-family: 'SF Mono', 'Menlo', monospace;
  font-size: 16rpx;
  font-weight: 400;
  line-height: 1;
  color: #B0A89E;
}

/* ─── 并排小卡 (cluster) ─── */
.card-cluster {
  flex: 1;
  display: grid;
  gap: 6rpx;
  align-items: stretch;
}

.cols-2 { grid-template-columns: repeat(2, 1fr); }
.cols-3 { grid-template-columns: repeat(3, 1fr); }
.cols-4 { grid-template-columns: repeat(4, 1fr); }

.era-mini {
  border-radius: 8rpx;
  background: transparent;
  border: 1rpx solid #EDEAE6;
  position: relative;
  overflow: hidden;
  box-sizing: border-box;
}

.era-mini--hover { opacity: 0.78; }

/* 小卡左上角 */
.mini-top-left {
  position: absolute;
  top: 6rpx;
  left: 12rpx;  /* 让开竖条 */
  right: 6rpx;
  display: flex;
  flex-direction: row;
  align-items: flex-start;
}

.mini-text-block {
  display: flex;
  flex-direction: column;
  gap: 2rpx;
  align-items: flex-start;
  min-width: 0;
  max-width: 100%;
}

/* 小卡字体由上方统一规则覆盖，此处仅保留 cols-4 左缩进微调 */
.cols-4 .mini-top-left { left: 4rpx; }
