@import '../../styles/atlas.wxss';

.page-shell {
  min-height: 100vh;
  background: #F8F6F2;
}

.overview-body {
  padding-bottom: 24rpx;
}

/* ─── 提示条 ─── */
.hint-bar {
  padding: 16rpx 32rpx;
  border-bottom: 1rpx solid #EDEAE6;
}

.hint-text { font-size: 22rpx; letter-spacing: 1rpx; }

/* ─── 地图 ─── */
.map-scroll {
  width: 100%;
  background: #EDF0F2;
}

.map-frame {
  position: relative;
  display: inline-block;
  min-width: 750rpx;
}

.map-image {
  width: 900rpx;
  display: block;
}

.civ-spot {
  position: absolute;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  transform: translate(-50%, -50%);
}

.spot-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(255,255,255,0.9);
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.2);
}

.spot-label {
  font-size: 16rpx;
  font-weight: 700;
  text-shadow: 0 1rpx 3rpx rgba(255,255,255,0.8);
  white-space: nowrap;
  background: rgba(255, 255, 255, 0.7);
  padding: 2rpx 8rpx;
  border-radius: 6rpx;
}

/* ─── 年代条 ─── */
.era-bar-section {
  padding: 16rpx 24rpx;
}

.dynasty-era-bar {
  display: flex;
  height: 48rpx;
  border-radius: 12rpx;
  overflow: hidden;
}

.era-seg {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18rpx;
  font-weight: 600;
}

.era-c1 { background: #84572F; color: #fff;    flex: 1.5; }
.era-c2 { background: #F1A805; color: #5A3A00; flex: 1; }
.era-c3 { background: #F2D6A1; color: #6B5E3A; flex: 1.5; }
.era-c4 { background: #92ADA4; color: #3A4A3E; flex: 0.8; }
.era-c5 { background: #B3D9E0; color: #3A5A6A; flex: 0.7; }
.era-c6 { background: #EDD5C0; color: #6A4A3A; flex: 0.5; }

/* ─── 文明网格 ─── */
.civ-list-section {
  padding: 0 24rpx;
}

.section-title-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.list-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #262626;
  letter-spacing: 2rpx;
}

.list-count { font-size: 22rpx; }

.civ-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.civ-grid-card {
  position: relative;
  height: 160rpx;
  border-radius: 16rpx;
  overflow: hidden;
  border: 1rpx solid rgba(255, 255, 255, 0.3);
}

.civ-card-img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.civ-card-overlay {
  position: absolute;
  inset: 0;
}

.civ-card-name {
  position: absolute;
  bottom: 12rpx;
  left: 0; right: 0;
  text-align: center;
  font-size: 24rpx;
  font-weight: 700;
  color: #FFFFFF;
  text-shadow: 0 1rpx 4rpx rgba(0,0,0,0.4);
  z-index: 2;
  letter-spacing: 2rpx;
}
