<view class="page-shell">
  <proto-nav title="{{box.title}}" show-back="{{true}}" />

  <!-- 内容 Tab 栏（紧跟导航栏） -->
  <view class="box-tabs-wrap" style="top: {{tabTop}}px;">
    <view wx:for="{{tabs}}" wx:key="*this" class="box-tab {{activeTab === index ? 'active' : ''}}" data-i="{{index}}" bindtap="onTabTap">{{item}}</view>
  </view>

  <!-- 内容滚动区（关系 Tab 禁用纵向滚动，避免与画布手势冲突） -->
  <scroll-view class="box-body-scroll" scroll-y="{{activeTab !== 1}}" enhanced show-scrollbar="{{false}}" style="top: {{bodyTop}}px;">

    <!-- Tab 0：详情 -->
    <view wx:if="{{activeTab === 0}}" class="box-tab1-body">
      <view wx:for="{{box.paragraphs}}" wx:key="*this" class="box-p">{{item}}</view>
    </view>

    <!-- Tab 1：关系图谱 -->
    <view wx:if="{{activeTab === 1}}" class="rel-tab-body">
      <view wx:if="{{relationTotal === 0}}" class="tab-empty">
        <text class="tab-empty-text">暂无关系数据</text>
      </view>
      <view wx:else class="rel-graph-wrap">
        <view class="rel-graph-viewport" style="height: {{canvasH}}px;">
          <canvas
            id="relationCanvas"
            type="2d"
            class="rel-graph-canvas"
            style="width: 100%; height: 100%;"
            bindtap="onCanvasTap"
            bindtouchstart="onGraphTouchStart"
            bindtouchmove="onGraphTouchMove"
            bindtouchend="onGraphTouchEnd"
            disable-scroll
          ></canvas>
        </view>
      </view>
    </view>

    <!-- Tab 2：评述 -->
    <view wx:if="{{activeTab === 2}}" class="box-tab-content">
      <view wx:if="{{critiques.length === 0}}" class="tab-empty">
        <text class="tab-empty-text">暂无评述数据</text>
      </view>
      <view wx:for="{{critiques}}" wx:key="title" wx:for-index="idx" class="crit-card" bindtap="onCritiqueTap" data-idx="{{idx}}">
        <!-- 头部：头像 + 作者 + 年代 -->
        <view class="crit-head">
          <view class="crit-avatar" style="background: {{critColors[idx % 6]}};">
            <text class="crit-avatar-text">{{item.author[0]}}</text>
          </view>
          <view class="crit-meta">
            <text class="crit-author">{{item.title}}</text>
            <text class="crit-era muted">{{item.author}} · {{item.era}} · {{item.book}}</text>
          </view>
          <text class="chev muted">›</text>
        </view>
        <!-- 分割线 -->
        <view class="crit-divider"></view>
        <!-- 简介 -->
        <text class="crit-body">{{item.summary}}</text>
      </view>
    </view>

    <!-- Tab 3：见证 -->
    <view wx:if="{{activeTab === 3}}" class="box-tab-content">
      <view wx:if="{{relics.length === 0}}" class="tab-empty">
        <text class="tab-empty-text">暂无文物数据</text>
      </view>
      <view wx:for="{{relics}}" wx:key="name" wx:for-index="idx" class="relic-card card-paper" bindtap="onRelicTap" data-idx="{{idx}}">
        <view class="relic-head">
          <view class="relic-thumb muted">🏛</view>
          <view class="relic-info">
            <view class="relic-name-row">
              <text class="relic-name">{{item.name}}</text>
            </view>
            <text class="relic-summary muted">{{item.summary}}</text>
            <text class="relic-location accent">◎ {{item.location}}</text>
          </view>
          <text class="chev muted">›</text>
        </view>
      </view>
    </view>

    <view wx:if="{{activeTab !== 1}}" style="height: 160rpx;"></view>
  </scroll-view>

  <!-- 关系 Tab 缩放栏（底部悬浮胶囊） -->
  <view wx:if="{{activeTab === 1 && relationTotal > 0}}" class="graph-zoom-bar">
    <view class="graph-zoom-btn" bindtap="onZoomOut">−</view>
    <text class="graph-zoom-label">{{graphScale}}</text>
    <view class="graph-zoom-btn" bindtap="onZoomIn">+</view>
  </view>

  <!-- 底部悬浮操作栏（仅详情 Tab） -->
  <view wx:if="{{activeTab === 0}}" class="box-bottom-bar">
    <view class="box-bottom-item" bindtap="onOriginalTap">
      <image class="box-bottom-img" src="/icons/yuanwen.png" mode="aspectFit" />
      <text class="box-bottom-label">原文</text>
    </view>
    <view class="box-bottom-item" bindtap="toggleAudio">
      <image class="box-bottom-img" src="/icons/bofang.png" mode="aspectFit" />
      <text class="box-bottom-label">播放</text>
    </view>
    <view class="box-bottom-item" bindtap="onFavoriteTap">
      <image class="box-bottom-img" src="{{isFavorited ? '/icons/shoucangB.png' : '/icons/shoucangA.png'}}" mode="aspectFit" />
      <text class="box-bottom-label {{isFavorited ? 'box-bottom-label--active' : ''}}">收藏</text>
    </view>
    <view class="box-bottom-item" bindtap="onShareTap">
      <image class="box-bottom-img" src="/icons/fenxiang.png" mode="aspectFit" />
      <text class="box-bottom-label">分享</text>
    </view>
  </view>

  <!-- 音频播放浮层（保持不变） -->
  <view class="box-audio-overlay {{audioOpen ? 'box-audio-overlay--open' : ''}}" hidden="{{!audioOpen}}">
    <view class="box-audio-top">
      <view class="box-audio-back" bindtap="toggleAudio">返回正文</view>
      <text class="box-audio-mode-title">音频播放</text>
      <view class="box-audio-top-spacer"></view>
    </view>
    <view class="box-audio-cover">朗读 · 史略解说</view>
    <view class="box-audio-scrub">
      <view class="box-audio-scrub-track">
        <view class="box-audio-scrub-fill" style="width: {{audioProgress}}%;"></view>
      </view>
      <view class="box-audio-time-row">
        <text>{{audioCurrentTime}}</text>
        <text>{{audioDuration}}</text>
      </view>
    </view>
    <view class="box-audio-play-row">
      <view class="box-audio-play" bindtap="togglePlay">{{playing ? '⏸' : '▶'}}</view>
    </view>
    <scroll-view class="box-audio-text" scroll-y show-scrollbar="{{false}}">
      <view wx:for="{{box.paragraphs}}" wx:key="*this" class="box-audio-para">{{item}}</view>
    </scroll-view>
  </view>

</view>
