@import '../../styles/atlas.wxss';

.page-shell {
  background: #F8F6F2;
  min-height: 100vh;
  overflow: hidden;
}

/* ─────────────────────────────────────
   英雄区（已移除）
───────────────────────────────────── */

/* ─────────────────────────────────────
   底部悬浮操作栏（胶囊组件）
───────────────────────────────────── */
.box-bottom-bar {
  position: fixed;
  bottom: 70rpx;
  left: 15%;
  width: 70%;
  z-index: 90;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-around;
  padding: 10rpx 0;
  background: rgba(255, 255, 255, 0.88);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border-radius: 999rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.06);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.10), 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.box-bottom-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  flex: 1;
}

.box-bottom-item:active {
  opacity: 0.5;
}

.box-bottom-img {
  width: 44rpx;
  height: 44rpx;
}

.box-bottom-label {
  font-size: 18rpx;
  font-weight: 500;
  color: #4A3F3F;
  letter-spacing: 0.3rpx;
}

.box-bottom-label--active {
  color: #9B3E38;
  font-weight: 600;
}

/* ─────────────────────────────────────
   内容 Tab 栏
───────────────────────────────────── */
.box-tabs-wrap {
  position: fixed;
  left: 0; right: 0;
  z-index: 80;
  display: flex;
  flex-direction: row;
  padding: 0 32rpx;
  background: rgba(248, 246, 242, 0.97);
  border-bottom: 1rpx solid #EDEAE6;
}

.box-tab {
  flex: 1;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: 'PingFang SC', -apple-system, sans-serif;
  font-size: 24rpx;   /* Body */
  font-weight: 500;
  color: #9A9A9A;     /* 未激活 */
  letter-spacing: 1rpx;
  position: relative;
}

.box-tab.active {
  color: #4A3F3F;     /* 主题色 */
  font-weight: 600;
}

.box-tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background: #4A3F3F;
  border-radius: 2rpx;
}

/* ─────────────────────────────────────
   内容滚动区
───────────────────────────────────── */
.box-body-scroll {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  overflow: hidden;
}

.box-tab1-body {
  padding: 32rpx 32rpx 24rpx;
}

/* Body：正文段落 */
.box-p {
  font-family: 'PingFang SC', -apple-system, sans-serif;
  font-size: 24rpx;   /* Body 12px */
  font-weight: 400;
  line-height: 1.78;
  color: #6A6A6A;     /* 正文 */
  letter-spacing: 0.3rpx;
  margin-bottom: 24rpx;
}

/* ─────────────────────────────────────
   通用 Tab 内容区
───────────────────────────────────── */
.box-tab-content {
  padding: 24rpx 24rpx 0;
}

.tab-empty {
  padding: 80rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tab-empty-text {
  font-size: 26rpx;
  color: #8A8A8A;
  letter-spacing: 1rpx;
}

.chev {
  font-size: 40rpx;
  color: #B0A89E;
  flex-shrink: 0;
}

/* ─────────────────────────────────────
   Tab 1：关系图谱
───────────────────────────────────── */
.rel-tab-body {
  padding: 0;
  height: 100%;
}

.rel-graph-wrap {
  padding: 0;
}

.rel-graph-viewport {
  position: relative;
  width: 100%;
  min-height: 400rpx;
  background: transparent;
  overflow: hidden;
  touch-action: none;
}

.rel-graph-canvas {
  display: block;
}

/* 关系 Tab 缩放栏 — 底部悬浮胶囊（宽度为详情操作栏一半） */
.graph-zoom-bar {
  position: fixed;
  bottom: 70rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 35%;
  z-index: 90;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-around;
  padding: 8rpx 16rpx;
  background: rgba(255, 255, 255, 0.88);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border-radius: 999rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.06);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.10), 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.graph-zoom-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #EDEAE6;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 500;
  color: #4A3F3F;
  line-height: 1;
  flex-shrink: 0;
}

.graph-zoom-btn:active {
  background: #D0CBC4;
}

.graph-zoom-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #4A3F3F;
  letter-spacing: 0.5rpx;
  font-variant-numeric: tabular-nums;
  min-width: 80rpx;
  text-align: center;
}

.rel-list-section {
  padding-top: 16rpx;
}

.rel-group {
  margin-bottom: 28rpx;
}

.rel-group-header {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 0 8rpx 12rpx;
}

.rel-group-icon {
  font-size: 28rpx;
}

.rel-group-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #262626;
  font-family: 'Noto Serif SC', 'PingFang SC', serif;
}

.rel-group-count {
  font-size: 22rpx;
  margin-left: 4rpx;
}

.rel-card {
  padding: 20rpx 24rpx;
  margin-bottom: 12rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  border: 1rpx solid #EDEAE6;
  box-shadow: 0 2rpx 8rpx rgba(47, 41, 38, 0.04);
}

.rel-card:active {
  background: #FAFAFA;
}

.rel-card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.rel-card-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #262626;
  font-family: 'Noto Serif SC', 'PingFang SC', serif;
}

.rel-card-role {
  font-size: 22rpx;
  font-weight: 600;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(0, 0, 0, 0.04);
}

.rel-card-summary {
  font-size: 24rpx;
  line-height: 1.6;
  display: block;
}

/* ─────────────────────────────────────
   Tab 2：评述
───────────────────────────────────── */
.crit-card {
  padding: 24rpx 24rpx;
  margin-bottom: 14rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  border: 1rpx solid #EDEAE6;
  box-shadow: 0 2rpx 8rpx rgba(47, 41, 38, 0.04);
}

.crit-card:active {
  background: #FAFAFA;
}

.crit-head {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-bottom: 14rpx;
}

.crit-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.1);
}

.crit-avatar-text {
  font-size: 28rpx;
  font-weight: 700;
  color: #FFFFFF;
  font-family: 'Noto Serif SC', serif;
}

.crit-meta {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.crit-author {
  font-size: 28rpx;
  font-weight: 600;
  color: #262626;
  font-family: 'Noto Serif SC', 'PingFang SC', serif;
}

.crit-era {
  font-size: 22rpx;
}

.crit-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #262626;
  display: block;
  margin-bottom: 8rpx;
  line-height: 1.4;
}

.crit-summary {
  font-size: 24rpx;
  line-height: 1.6;
  display: block;
  margin-bottom: 10rpx;
}

.crit-book {
  font-size: 22rpx;
  font-style: italic;
  display: block;
}

/* ── 分割线 ── */
.crit-divider {
  height: 1rpx;
  background: #EDEAE6;
  margin-bottom: 18rpx;
}

/* ── 出处 ── */
.crit-src {
  margin-bottom: 14rpx;
  font-size: 22rpx;
  display: block;
  font-style: italic;
}

/* ── 正文 ── */
.crit-body {
  font-size: 28rpx;
  line-height: 1.7;
  color: #6A6A6A;
  display: block;
}

/* ─────────────────────────────────────
   Tab 3：见证（文物）
───────────────────────────────────── */
.relic-card {
  padding: 20rpx 24rpx;
  margin-bottom: 14rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  border: 1rpx solid #EDEAE6;
  box-shadow: 0 2rpx 8rpx rgba(47, 41, 38, 0.04);
}

.relic-card:active {
  background: #FAFAFA;
}

.relic-head {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.relic-thumb {
  width: 80rpx;
  height: 80rpx;
  border-radius: 12rpx;
  background: #F5F3F0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  flex-shrink: 0;
}

.relic-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.relic-name-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.relic-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #262626;
  font-family: 'Noto Serif SC', 'PingFang SC', serif;
}

.relic-summary {
  font-size: 24rpx;
  line-height: 1.5;
}

.relic-location {
  font-size: 22rpx;
  display: block;
  margin-top: 4rpx;
}

/* ─────────────────────────────────────
   音频播放浮层
───────────────────────────────────── */
.box-audio-overlay {
  position: fixed;
  inset: 0;
  background: #F8F6F2;
  z-index: 200;
  display: flex;
  flex-direction: column;
  padding: 0 0 40rpx;
  box-sizing: border-box;
}

.box-audio-top {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 24rpx 32rpx;
}

.box-audio-back {
  font-family: 'PingFang SC', -apple-system, sans-serif;
  font-size: 26rpx;
  font-weight: 500;
  color: #4A3F3F;
  letter-spacing: 0.5rpx;
  padding: 8rpx 0;
}

.box-audio-mode-title {
  flex: 1;
  text-align: center;
  font-family: 'PingFang SC', -apple-system, sans-serif;
  font-size: 28rpx;
  font-weight: 600;
  color: #262626;
  letter-spacing: 2rpx;
}

.box-audio-top-spacer { width: 80rpx; }

.box-audio-cover {
  margin: 16rpx 48rpx 32rpx;
  height: 200rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #EDEAE6, #E0DDD9);
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: 'PingFang SC', -apple-system, sans-serif;
  font-size: 24rpx;
  color: #8A8A8A;
  letter-spacing: 2rpx;
}

.box-audio-scrub {
  padding: 0 48rpx;
  margin-bottom: 32rpx;
}

.box-audio-scrub-track {
  height: 4rpx;
  background: #E0DEDC;
  border-radius: 4rpx;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.box-audio-scrub-fill {
  height: 100%;
  background: #4A3F3F;
  border-radius: 4rpx;
  width: 28%;
}

.box-audio-time-row {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  font-family: 'SF Mono', 'Menlo', monospace;
  font-size: 20rpx;
  color: #B0A89E;
  font-variant-numeric: tabular-nums;
}

.box-audio-play-row {
  display: flex;
  justify-content: center;
  margin-bottom: 32rpx;
}

.box-audio-play {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: rgba(74, 63, 63, 0.08);
  border: 2rpx solid rgba(74, 63, 63, 0.18);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  color: #4A3F3F;
}

.box-audio-text {
  flex: 1;
  padding: 0 48rpx;
  overflow: hidden;
}

.box-audio-para {
  font-family: 'PingFang SC', -apple-system, sans-serif;
  font-size: 24rpx;
  font-weight: 400;
  line-height: 1.78;
  color: #6A6A6A;
  margin-bottom: 20rpx;
}
