@import '../../styles/atlas.wxss';

/* ══════════════════════════════════════════
   史略评述列表页 · 仿小红书评论区样式
══════════════════════════════════════════ */

/* ── 顶部信息栏 ── */
.page-header {
  padding: 24rpx 32rpx 20rpx;
  background: #FFFFFF;
  border-bottom: 1rpx solid #EDEAE6;
}

.header-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #262626;
  font-family: 'Noto Serif SC', 'PingFang SC', serif;
}

.header-sub {
  font-size: 24rpx;
}

/* ── 滚动容器 ── */
.critique-scroll {
  height: calc(100vh - 88px - 80rpx);
  padding: 16rpx 0;
  box-sizing: border-box;
}

/* ── 主评述卡片 ── */
.critique-card {
  background: #FFFFFF;
  margin: 0 24rpx 16rpx;
  border-radius: 20rpx;
  border: 1rpx solid #EDEAE6;
  box-shadow: 0 2rpx 8rpx rgba(47, 41, 38, 0.04);
  padding: 28rpx 28rpx 20rpx;
}

.critique-card:active {
  background: #FAFAFA;
}

/* ── 头部：头像 + 作者 ── */
.critique-head {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.12);
}

.avatar-sm {
  width: 56rpx;
  height: 56rpx;
}

.avatar-text {
  font-size: 32rpx;
  font-weight: 700;
  color: #FFFFFF;
  font-family: 'Noto Serif SC', serif;
}

.avatar-sm .avatar-text {
  font-size: 26rpx;
}

.critique-meta {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.critique-author {
  font-size: 30rpx;
  font-weight: 600;
  color: #262626;
  font-family: 'Noto Serif SC', 'PingFang SC', serif;
}

.critique-era {
  font-size: 22rpx;
  line-height: 1.3;
}

/* ── 正文 ── */
.critique-body {
  font-size: 28rpx;
  line-height: 1.8;
  color: #3A3A3A;
  display: block;
  margin-bottom: 12rpx;
  /* 最多显示 4 行 */
  display: -webkit-box;
  -webkit-line-clamp: 4;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* ── 来源 ── */
.critique-source {
  font-size: 22rpx;
  font-style: italic;
  display: block;
  margin-bottom: 16rpx;
  color: #8A8A8A;
}

/* ── 底部操作栏 ── */
.critique-actions {
  display: flex;
  align-items: center;
  gap: 32rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid #F0EDE8;
}

.action-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 0;
}

.action-icon {
  font-size: 28rpx;
  color: #8A8A8A;
}

.action-count {
  font-size: 22rpx;
  color: #8A8A8A;
}

.action-btn.liked .action-icon {
  color: #E85D5D;
}

.action-btn.liked .action-count {
  color: #E85D5D;
}

/* ── 回复区域 ── */
.replies-section {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #F0EDE8;
}

.replies-toggle {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 0;
}

.toggle-text {
  font-size: 24rpx;
  color: #5B8CB8;
  font-weight: 500;
}

.toggle-arrow {
  font-size: 24rpx;
  color: #5B8CB8;
  transform: rotate(90deg);
  transition: transform 0.2s ease;
}

.toggle-arrow.arrow-up {
  transform: rotate(-90deg);
}

/* ── 回复卡片 ── */
.replies-list {
  margin-top: 12rpx;
  padding-left: 16rpx;
  border-left: 4rpx solid #EDEAE6;
}

.reply-card {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F5F3F0;
}

.reply-card:last-child {
  border-bottom: none;
}

.reply-head {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.reply-meta {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 2rpx;
}

.reply-author-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.reply-author {
  font-size: 26rpx;
  font-weight: 600;
  color: #262626;
  font-family: 'Noto Serif SC', 'PingFang SC', serif;
}

.reply-to {
  font-size: 22rpx;
}

.reply-era {
  font-size: 20rpx;
}

.reply-body {
  font-size: 26rpx;
  line-height: 1.7;
  color: #4A4A4A;
  display: block;
  margin-bottom: 10rpx;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.reply-card .critique-source {
  margin-bottom: 12rpx;
}

.reply-card .critique-actions {
  padding-top: 8rpx;
}
