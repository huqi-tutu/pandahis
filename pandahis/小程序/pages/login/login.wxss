@import '../../styles/atlas.wxss';

.page-shell {
  min-height: 100vh;
  background: linear-gradient(165deg, rgba(155,62,56,0.08) 0%, #FAF7F3 40%);
}

.login-body {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 60rpx 48rpx 80rpx;
  box-sizing: border-box;
}

/* ─── Logo ─── */
.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
}

.logo-icon {
  width: 160rpx;
  height: 160rpx;
  border-radius: 40rpx;
  background: linear-gradient(135deg, rgba(155,62,56,0.12), rgba(155,62,56,0.04));
  border: 1rpx solid rgba(155, 62, 56, 0.12);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(155, 62, 56, 0.1);
}

.logo-img {
  width: 100rpx;
  height: 100rpx;
  opacity: 0.7;
}

.logo-title {
  font-family: 'PingFang SC', serif;
  font-size: 52rpx;
  font-weight: 700;
  color: #262626;
  letter-spacing: 8rpx;
  margin-bottom: 12rpx;
}

.logo-sub {
  font-size: 24rpx;
  letter-spacing: 4rpx;
}

/* ─── 登录区域 ─── */
.login-section {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* 微信按钮 */
.btn-wechat {
  width: 100%;
  height: 96rpx;
  background: #07C160;
  color: #FFFFFF;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  border: none;
  box-shadow: 0 4rpx 16rpx rgba(7, 193, 96, 0.25);
}

.btn-wechat::after { border: none; }
.btn-wechat-icon { font-size: 36rpx; }

/* 手机号 */
.phone-section {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.input-group {
  width: 100%;
}

.input-wrap {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 16rpx;
  border: 1rpx solid #EDEAE6;
  padding: 0 24rpx;
  height: 96rpx;
  gap: 16rpx;
}

.input-prefix {
  font-size: 28rpx;
  flex-shrink: 0;
}

.phone-input,
.code-input {
  flex: 1;
  font-size: 28rpx;
  color: #262626;
  background: transparent;
}

.input-placeholder {
  color: #B0A89E;
  font-size: 28rpx;
}

.send-code {
  flex-shrink: 0;
  font-size: 24rpx;
  color: #9B3E38;
  font-weight: 600;
  padding: 8rpx 0 8rpx 16rpx;
  border-left: 1rpx solid #EDEAE6;
}

.send-code.disabled { color: #B0A89E; }

.btn-phone {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  font-size: 30rpx;
  letter-spacing: 2rpx;
  box-shadow: 0 4rpx 16rpx rgba(74, 63, 63, 0.2);
}

/* 分隔线 */
.divider-line {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin: 4rpx 0;
}

.divider-seg {
  flex: 1;
  height: 1rpx;
  background: #EDEAE6;
}

.divider-text { font-size: 22rpx; }

/* 游客 */
.guest-btn {
  text-align: center;
  padding: 16rpx;
  font-size: 26rpx;
}

/* ─── 协议 ─── */
.agreement {
  margin-top: 40rpx;
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  align-items: center;
  gap: 4rpx;
}

.agree-text { font-size: 22rpx; }
.agree-link { font-size: 22rpx; }
