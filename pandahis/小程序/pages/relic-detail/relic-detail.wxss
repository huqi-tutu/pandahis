@import '../../styles/atlas.wxss';

/* ── 图片占位 ── */
.hero-img {
  height: 400rpx;
  border-radius: 20rpx;
  margin-bottom: 28rpx;
  background: linear-gradient(145deg, rgba(155,62,56,0.05), rgba(250,247,243,1));
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid #EDEAE6;
  font-size: 80rpx;
  color: #D0CBC4;
}

/* ── 主信息卡片 ── */
.info-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  border: 1rpx solid #EDEAE6;
  padding: 28rpx 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(47, 41, 38, 0.04);
}

.info-header {
  margin-bottom: 20rpx;
}

.relic-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #262626;
  line-height: 1.3;
  font-family: 'Noto Serif SC', 'PingFang SC', serif;
}

.info-divider {
  height: 1rpx;
  background: #EDEAE6;
  margin-bottom: 18rpx;
}

.info-location {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.location-icon {
  font-size: 24rpx;
  color: #92ADA4;
  flex-shrink: 0;
}

.location-text {
  font-size: 24rpx;
  color: #6A6A6A;
}

/* ── 分区卡片 ── */
.section-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  border: 1rpx solid #EDEAE6;
  padding: 28rpx 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(47, 41, 38, 0.04);
}

.section-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.section-bar {
  width: 6rpx;
  height: 28rpx;
  background: #92ADA4;
  border-radius: 3rpx;
}

.section-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #4A3F3F;
  font-family: 'Noto Serif SC', 'PingFang SC', serif;
}

.section-body {
  font-size: 28rpx;
  line-height: 1.8;
  color: #6A6A6A;
  display: block;
}
