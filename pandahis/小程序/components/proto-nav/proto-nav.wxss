/* 对齐原型 .nav-bar：高度 44px → 88rpx，底色 --ui-nav-bg */
.proto-nav-root {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 1000;
  background: rgba(250, 247, 243, 0.96);
  border-bottom: 1rpx solid rgba(101, 53, 49, 0.12);
}

.proto-status-h {
  width: 100%;
}

.proto-bar {
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 40rpx;
  box-sizing: border-box;
}

.proto-bar--home {
  position: relative;
  justify-content: flex-start;
}

.proto-home-left {
  min-width: 160rpx;
  flex-shrink: 0;
  z-index: 5;
  position: relative;
}

.proto-home-right {
  margin-left: auto;
  min-width: 80rpx;
  display: flex;
  justify-content: flex-end;
  flex-shrink: 0;
  z-index: 5;
  position: relative;
}

.proto-mode-pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 56rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: rgba(155, 62, 56, 0.1);
  border: 1rpx solid rgba(155, 62, 56, 0.22);
  color: #9b3e38;
  font-size: 24rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
  line-height: 1;
  box-sizing: border-box;
}

.proto-mode-pill--icon {
  width: 56rpx;
  padding: 0;
  background: transparent;
  border: none;
}

.proto-mode-pill-icon {
  width: 40rpx;
  height: 40rpx;
  display: block;
}

.proto-title--center {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  z-index: 1;
  max-width: 52%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  pointer-events: none;
}

.proto-side {
  min-width: 64rpx;
  display: flex;
  align-items: center;
}

.proto-side--left {
  justify-content: flex-start;
}

.proto-side--right {
  justify-content: flex-end;
}

.proto-back {
  font-size: 48rpx;
  color: rgba(47, 41, 38, 0.76);
  line-height: 1;
  padding: 8rpx 16rpx 8rpx 0;
}

.proto-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2f2926;
  letter-spacing: 4rpx;
}

.proto-title--flex {
  flex: 1;
  text-align: center;
  padding: 0 16rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
