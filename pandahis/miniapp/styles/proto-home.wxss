/* 对齐原型卡片色 + 模式胶囊样式 */

/* ─── 模式胶囊 ─── */
.proto-mode-switch {
  height: 52rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: rgba(155, 62, 56, 0.08);
  border: 1rpx solid rgba(155, 62, 56, 0.14);
  color: #9b3e38;
  font-size: 22rpx;
  font-weight: 600;
  letter-spacing: 1.2rpx;
  line-height: 1;
}
.proto-mode-switch::after { border: none; }
