<navigation-bar title="我的收藏" back="{{true}}" color="#4a3230" background="rgba(255,248,247,0.92)"></navigation-bar>

<view class="page-fav">
  <empty-state
    wx:if="{{!hasToken}}"
    type="login"
    title="需要登录"
    desc="登录后可查看收藏列表。"
    cta="去登录"
    bind:cta="goLogin"
  ></empty-state>

  <block wx:elif="{{loaded}}">
    <view class="tabs" wx:if="{{dynastyCount || shilueCount}}">
      <view
        class="tab {{activeTab === 'dynasty' ? 'tab-active' : ''}}"
        data-tab="dynasty"
        bindtap="onTab"
      >
        <text>朝代</text>
        <text class="tab-count">{{dynastyCount}}</text>
      </view>
      <view
        class="tab {{activeTab === 'shilue' ? 'tab-active' : ''}}"
        data-tab="shilue"
        bindtap="onTab"
      >
        <text>史略</text>
        <text class="tab-count">{{shilueCount}}</text>
      </view>
    </view>

    <view wx:if="{{!visibleItems.length}}" class="empty-wrap">
      <empty-state
        type="favorites"
        title="{{activeTab === 'dynasty' ? '暂无朝代收藏' : '暂无史略收藏'}}"
        desc="在历史盒子详情页点亮红心即可收藏。"
      ></empty-state>
    </view>

    <scroll-view wx:else class="list-scroll" scroll-y enhanced show-scrollbar="{{false}}">
      <view class="card-list">
        <view
          class="fav-card"
          wx:for="{{visibleItems}}"
          wx:key="boxId"
          bindtap="go"
          data-id="{{item.boxId}}"
        >
          <view class="card-head">
            <text class="card-title">{{item.title}}</text>
            <text class="card-date">{{item.dateLabel}}</text>
          </view>
          <view class="card-years">{{item.yearRange}}</view>
          <view class="card-path" wx:if="{{item.pathLabel}}">{{item.pathLabel}}</view>
        </view>
      </view>
    </scroll-view>
  </block>

  <view wx:else class="loading">加载中…</view>
</view>
