<view class="page-shell">
  <proto-nav title="我的收藏" show-back="{{true}}"></proto-nav>

  <view class="fav-body" style="padding-top: {{headerPadPx}}px;">
    <view wx:if="{{!hasToken}}" class="empty-state">
      <text class="empty-icon">🔒</text>
      <text class="empty-text">登录后可查看收藏列表</text>
      <view class="login-btn btn-primary" bindtap="goLogin">去登录</view>
    </view>

    <block wx:elif="{{loaded}}">
      <view class="tabs" wx:if="{{dynastyCount || shilueCount}}">
        <view
          class="tab {{activeTab === 'dynasty' ? 'on' : ''}}"
          data-tab="dynasty"
          bindtap="onTab"
        >
          <text>朝代</text>
          <text class="tab-count">{{dynastyCount}}</text>
        </view>
        <view
          class="tab {{activeTab === 'shilue' ? 'on' : ''}}"
          data-tab="shilue"
          bindtap="onTab"
        >
          <text>史略</text>
          <text class="tab-count">{{shilueCount}}</text>
        </view>
      </view>

      <view wx:if="{{!visibleItems.length}}" class="empty-state">
        <text class="empty-icon">☆</text>
        <text class="empty-text">{{activeTab === 'dynasty' ? '暂无朝代收藏' : '暂无史略收藏'}}</text>
        <text class="empty-hint">在历史盒子详情页点亮红心即可收藏</text>
      </view>

      <view wx:else class="card-list">
        <view
          class="card card-paper"
          wx:for="{{visibleItems}}"
          wx:key="boxId"
          data-id="{{item.boxId}}"
          bindtap="go"
        >
          <view class="top">
            <text class="t">{{item.title}}</text>
            <text class="time muted">{{item.dateLabel}}</text>
          </view>
          <text class="era accent">{{item.yearRange}}</text>
          <text wx:if="{{item.pathLabel}}" class="path muted">{{item.pathLabel}}</text>
        </view>
      </view>
    </block>

    <view wx:else class="loading">加载中…</view>
  </view>
</view>
