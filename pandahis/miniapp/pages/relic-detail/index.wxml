<view class="proto-shell">
  <proto-nav title="{{name}}" show-back="{{true}}"></proto-nav>

  <view class="detail-body" style="padding-top: {{headerPadPx}}px;">
    <image wx:if="{{imageUrl}}" class="hero-img-real" src="{{imageUrl}}" mode="aspectFill" />
    <view wx:else class="hero-img muted">文物图片占位</view>

    <view class="info-card card-paper">
      <view class="info-header">
        <text class="relic-title">{{name}}</text>
      </view>
      <view wx:if="{{museum}}" class="info-divider"></view>
      <view wx:if="{{museum}}" class="info-location">
        <text class="location-icon">◎</text>
        <text class="location-text">{{museum}}</text>
      </view>
    </view>

    <view class="section-card card-paper">
      <view class="section-header">
        <view class="section-bar"></view>
        <text class="section-title">详细介绍</text>
      </view>
      <text class="section-body">{{detail || '暂无详细介绍'}}</text>
    </view>
  </view>
</view>
