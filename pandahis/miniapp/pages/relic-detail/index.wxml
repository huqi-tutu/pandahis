<navigation-bar title="{{name}}" back="{{true}}" color="#4A3F3F" background="rgba(248,246,242,0.96)"></navigation-bar>

<view class="detail-page">
  <image wx:if="{{imageUrl}}" class="hero-img" src="{{imageUrl}}" mode="aspectFill" />
  <view wx:else class="hero-placeholder">🏛</view>
  <view class="info-card">
    <text class="relic-title">{{name}}</text>
    <view wx:if="{{museum}}" class="location">◎ {{museum}}</view>
  </view>
  <text class="sec">详细介绍</text>
  <view class="text-card">{{detail || '暂无详细介绍'}}</view>
</view>
