<navigation-bar
  title="{{navTitle}}"
  back="{{true}}"
  color="#4A3F3F"
  background="rgba(255,248,247,0.96)"
>
  <view slot="right" class="ud-nav-more" bindtap="onShareTap">分享</view>
</navigation-bar>

<view wx:if="{{unit && swim}}" class="ud-page">
  <view class="unit-civ-tabs" style="top: {{scrollTop}}px;">
    <scroll-view class="unit-region-scroll" scroll-x show-scrollbar="{{false}}" enhanced>
      <view class="unit-region-inner">
        <view wx:for="{{concurrentItems}}" wx:key="*this" class="unit-civ-tab {{index === 0 ? 'active' : ''}}">{{item}}</view>
      </view>
    </scroll-view>
  </view>

  <scroll-view class="dynasty-scroll" scroll-y enhanced show-scrollbar="{{false}}" bindscroll="onDynastyScroll">
    <view class="ud-hero">
      <view class="ud-hero-top">
        <view class="ud-hero-titles">
          <view class="ud-hero-title">{{heroDynastyTitle}}</view>
          <view class="ud-hero-sub">{{heroSubLine}}</view>
          <view wx:if="{{nextUnit}}" class="ud-hero-next" bindtap="goNext">
            <text>下一朝代：{{nextUnit.title}} ›</text>
          </view>
        </view>
        <view class="ud-hero-actions">
          <view class="ud-icon-btn {{isFav ? 'ud-icon-btn--fav-on' : ''}}" bindtap="onFavoriteTap">
            <text>{{isFav ? '♥' : '♡'}}</text>
          </view>
        </view>
      </view>
      <view class="ud-hero-intro">
        <text>{{introPreview}}</text>
        <text wx:if="{{introCanExpand}}" class="ud-detail-link" bindtap="openIntro">全部›</text>
      </view>
    </view>

    <view class="dyn-swim-matrix">
      <view wx:if="{{axisPinned && swim}}" class="dyn-swim-axis dyn-swim-axis--fixed" style="top: {{scrollTop}}px;">
        <view class="dyn-swim-axis-inner">
          <text wx:for="{{swim.ticks}}" wx:key="label" class="dyn-swim-axis-tick" style="left: {{item.left}};">{{item.label}}</text>
          <text class="dyn-swim-axis-tick dyn-swim-axis-tick--end" style="left:100%;">{{swim.endLabel}}</text>
        </view>
      </view>
      <scroll-view class="dyn-swim-hscroll" scroll-x show-scrollbar="{{false}}" scroll-left="{{swimScrollLeft}}" bindscroll="onSwimHScroll">
        <view class="dyn-swim-sheet" style="width: {{swim.sheetWidthRpx}}rpx;">
          <view class="dyn-swim-axis">
            <view class="dyn-swim-axis-inner">
              <text wx:for="{{swim.ticks}}" wx:key="label" class="dyn-swim-axis-tick" style="left: {{item.left}};">{{item.label}}</text>
              <text class="dyn-swim-axis-tick dyn-swim-axis-tick--end" style="left:100%;">{{swim.endLabel}}</text>
            </view>
          </view>
          <view class="dyn-swim-lanes">
            <view wx:for="{{swim.lanes}}" wx:for-index="li" wx:key="label" class="dyn-swim-lane" style="border-left-color: {{item.borderColor}};">
              <view class="dyn-swim-lane-head"><text>{{item.label}}</text></view>
              <view wx:if="{{item.layout === 'shichen'}}" class="dyn-swim-track">
                <view class="dyn-swim-track-grid"></view>
                <view class="dyn-swim-stack dyn-swim-stack--shichen">
                  <view wx:for="{{item.collapsedRows}}" wx:for-item="row" wx:for-index="ri" wx:key="ri" class="dyn-swim-row">
                    <view
                      wx:for="{{row}}"
                      wx:for-item="bar"
                      wx:key="title"
                      class="dyn-shichen-unit"
                      style="left: {{bar.unitLeft || bar.left}}; width: calc({{bar.unitWidth || bar.width}} - 2rpx); z-index: {{bar.zIndex || 10}};"
                      bindtap="onBarTap"
                      data-box="{{bar.boxId}}"
                    >
                      <view class="dyn-shichen-line dyn-shichen-line--left" style="width: {{bar.lineLeftW || '20%'}};"></view>
                      <view class="dyn-shichen-chip dyn-shichen-chip--{{bar.type || 'default'}}" style="left: {{bar.chipLeft || '50%'}};">{{bar.title}}</view>
                      <view class="dyn-shichen-line dyn-shichen-line--right" style="left: {{bar.lineRightL || '80%'}}; width: {{bar.lineRightW || '20%'}};"></view>
                    </view>
                  </view>
                </view>
              </view>
              <view wx:elif="{{item.layout === 'continuous'}}" class="dyn-swim-track">
                <view class="dyn-swim-track-grid"></view>
                <view class="dyn-swim-stack dyn-swim-stack--continuous">
                  <view wx:for="{{item.collapsedRows}}" wx:for-item="row" wx:for-index="ri" wx:key="ri" class="dyn-swim-row">
                    <view
                      wx:for="{{row}}"
                      wx:for-item="bar"
                      wx:key="title"
                      class="dyn-continuous-unit"
                      style="left: {{bar.unitLeft || bar.left}}; width: calc({{bar.unitWidth || bar.width}} - 2rpx);"
                      bindtap="onBarTap"
                      data-box="{{bar.boxId}}"
                    >
                      <view class="dyn-continuous-line dyn-continuous-line--left" style="width: {{bar.lineLeftW || '12%'}};"></view>
                      <view class="dyn-continuous-chip dyn-continuous-chip--{{bar.priority}}" style="left: {{bar.chipLeft || '0'}}; width: {{bar.chipWidth || bar.width}};">{{bar.title}}</view>
                      <view class="dyn-continuous-line dyn-continuous-line--right" style="left: {{bar.lineRightL || '88%'}}; width: {{bar.lineRightW || '12%'}};"></view>
                    </view>
                  </view>
                </view>
              </view>
              <view wx:else class="dyn-swim-track">
                <view wx:for="{{item.collapsedRows}}" wx:for-item="row" wx:for-index="ri" wx:key="ri" class="dyn-swim-row">
                  <view
                    wx:for="{{row}}"
                    wx:for-item="bar"
                    wx:key="title"
                    class="dyn-swim-bar dyn-swim-bar--isolated dyn-swim-bar--{{bar.priority}}"
                    style="left: {{bar.left}}; width: {{bar.width}};"
                    bindtap="onBarTap"
                    data-box="{{bar.boxId}}"
                  >{{bar.title}}</view>
                </view>
              </view>
              <view wx:if="{{item.hasMore}}" class="dyn-swim-more" bindtap="showMoreOverlay" data-lane="{{li}}" data-label="{{item.label}}">
                +{{item.moreCount}} ›
              </view>
            </view>
          </view>
        </view>
      </scroll-view>
    </view>

    <view wx:if="{{relatedUnits.length}}" class="ud-related">
      <view class="ud-related-label">年份相近的其他地域</view>
      <scroll-view scroll-x class="ud-related-x" enhanced show-scrollbar="{{false}}">
        <view class="ud-related-inner">
          <view wx:for="{{relatedUnits}}" wx:key="unitId" class="ud-related-chip" bindtap="goUnit" data-id="{{item.unitId}}">
            <text>{{item.title}}</text>
          </view>
        </view>
      </scroll-view>
    </view>
    <view class="ud-foot">点击泳道条目进入史略盒子</view>
  </scroll-view>
</view>

<view class="ud-modal" wx:if="{{showIntroModal}}" bindtap="closeIntro">
  <view class="ud-modal-card" catchtap="noop">
    <view class="ud-modal-title">朝代简介</view>
    <scroll-view scroll-y class="ud-modal-body">{{unit.summary}}</scroll-view>
    <view class="ud-modal-btn" bindtap="closeIntro">关闭</view>
  </view>
</view>

<view wx:if="{{overlayVisible}}" class="more-overlay-backdrop" bindtap="hideOverlay">
  <view class="more-overlay-sheet" catchtap="">
    <view class="more-overlay-title">{{overlayLabel}} · 更多史略</view>
    <scroll-view scroll-y class="more-overlay-list">
      <view wx:for="{{overlayBars}}" wx:key="title" class="more-overlay-item" bindtap="onBarTap" data-box="{{item.boxId}}">
        <text>{{item.title}}</text>
        <text wx:if="{{item.timeRange}}" class="more-overlay-range">{{item.timeRange}}</text>
      </view>
    </scroll-view>
  </view>
</view>
