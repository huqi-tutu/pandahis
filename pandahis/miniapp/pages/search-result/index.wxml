<view class="page-shell">
  <proto-nav title="搜索结果" show-back="{{true}}"></proto-nav>

  <view class="result-body" style="padding-top: {{headerPadPx}}px;">
    <!-- 关键词展示 + 结果数 -->
    <view class="kw-bar">
      <text class="kw-text">「{{keyword}}」</text>
      <text class="kw-count muted">共 {{resultTotal}} 条</text>
    </view>

    <!-- 类别筛选 -->
    <view class="filter-bar" wx:if="{{results.length}}">
      <scroll-view scroll-x class="filter-scroll" enhanced show-scrollbar="{{false}}">
        <view class="filter-inner">
          <view
            wx:for="{{filterCats}}"
            wx:key="*this"
            class="filter-tag {{filterIndex === index ? 'active' : ''}}"
            data-i="{{index}}"
            bindtap="onFilter"
          >{{item}}</view>
        </view>
      </scroll-view>
    </view>

    <!-- 结果列表 -->
    <view wx:if="{{searching}}" class="loading muted">搜索中…</view>

    <view wx:elif="{{!filteredResults.length}}" class="empty-state">
      <text class="empty-icon">🔍</text>
      <text class="empty-text">未找到结果</text>
      <text class="muted" style="font-size:24rpx;">换个关键词试试？</text>
    </view>

    <scroll-view wx:else scroll-y class="result-scroll" enhanced show-scrollbar="{{false}}">
      <view
        class="result-card"
        wx:for="{{filteredResults}}"
        wx:key="key"
        bindtap="go"
        data-type="{{item.type}}"
        data-id="{{item.id}}"
      >
        <view wx:if="{{item.category}}" class="result-cat-badge">
          <text>{{item.category}}</text>
        </view>
        <view class="result-main">
          <rich-text class="result-title" nodes="{{item.titleRich}}"></rich-text>
          <text class="result-sub faint">{{item.pathText}}</text>
          <rich-text wx:if="{{item.hasDesc}}" class="result-snippet muted" nodes="{{item.descRich}}"></rich-text>
        </view>
        <text class="result-arrow muted">›</text>
      </view>

      <view style="height: 60rpx;"></view>
    </scroll-view>
  </view>
</view>
