<view class="page-shell">
  <proto-nav title="邀请助力" show-back="{{true}}"></proto-nav>

  <scroll-view
    class="page-assist"
    scroll-y enhanced show-scrollbar="{{false}}"
    style="padding-top: {{headerPadPx}}px;"
  >
    <!-- 会员卡：PNG 圆角透明底卡片 + 文字叠加 -->
    <view class="vip-inv-card {{rewardClaimed ? 'vip-inv-card--claimed' : ''}}">
      <image class="vip-inv-card-bg" src="/配图/vipcar.png" mode="widthFix" />
      <view class="vip-inv-card-overlay">
        <view class="vip-inv-card-head">
          <text class="vip-inv-card-title">{{durationDays}}天VIP会员体验卡</text>
          <view class="vip-inv-chips">
            <text wx:if="{{rewardClaimed}}" class="vip-inv-chip vip-inv-chip--ok">已获得</text>
            <text wx:if="{{rewardClaimed && endDateLabel}}" class="vip-inv-chip">到期日：{{endDateLabel}}</text>
            <text wx:if="{{!rewardClaimed}}" class="vip-inv-chip">助力免费领</text>
          </view>
        </view>
        <text class="vip-inv-card-line">图谱高级权限 · 评述 · 见证 · 全文对照</text>
        <text wx:if="{{rewardClaimed}}" class="vip-inv-card-line vip-inv-card-line--sub">有效期内随时可用</text>
      </view>
    </view>

    <view class="status-block">
      <view class="status-title">邀请 {{targetCount}} 名好友助力，限时完成领奖励</view>
      <view class="status-progress muted">
        助力进度：<text class="strong">{{currentCount}} / {{targetCount}}</text>
      </view>
      <view wx:if="{{deadlineLabel && !rewardClaimed}}" class="status-deadline muted {{assistExpired ? 'expired' : ''}}">
        {{assistExpired ? '活动已截止' : '请在'}}<text wx:if="{{!assistExpired}}">{{deadlineLabel}} 前完成</text>
      </view>
    </view>

    <view class="slots">
      <view class="slot" wx:for="{{slots}}" wx:key="index">
        <view wx:if="{{item.filled}}" class="slot-avatar filled">
          <view class="slot-inner">
            <image
              wx:if="{{item.avatarUrl}}"
              class="slot-img"
              src="{{item.avatarUrl}}"
              mode="aspectFill"
            />
            <text wx:else class="slot-char">{{item.label}}</text>
          </view>
        </view>
        <view wx:else class="slot-avatar empty">
          <view class="slot-plus"></view>
        </view>
        <text class="slot-label muted {{item.filled ? 'slot-label-done' : ''}}">{{item.filled ? '已助力' : '待加入'}}</text>
      </view>
    </view>

    <view wx:if="{{completed && !rewardClaimed && !assistExpired}}" class="claim-hint">
      助力已满，正在为你开通季度会员…
    </view>
    <view wx:if="{{assistExpired && !rewardClaimed}}" class="claim-hint expired-hint muted">
      本期助力已截止，可付费开通会员或邀请好友获取阅读点
    </view>
  </scroll-view>

  <view class="footer-bar">
    <button
      wx:if="{{canShare}}"
      class="share-btn"
      open-type="share"
    >邀请好友</button>
    <view wx:else class="share-btn" bindtap="onInviteFriends">邀请好友</view>
  </view>
</view>
