<proto-nav title="编辑资料" show-back="{{true}}"></proto-nav>

<view class="page" style="padding-top: {{headerPadPx}}px;">
  <view class="card-paper card">
    <view class="title text-h2">昵称</view>
    <view class="desc">1–32 个字符，将显示在「我的」页。</view>
    <input
      class="input"
      value="{{nickname}}"
      maxlength="32"
      placeholder="请输入昵称"
      placeholder-class="input-ph"
      bindinput="onInput"
      confirm-type="done"
      bindconfirm="onSave"
    />
    <view class="save-btn {{saving ? 'disabled' : ''}}" bindtap="onSave">{{saving ? '保存中…' : '保存'}}</view>
  </view>
</view>
