<view class="page-search">
  <!-- TopAppBar（对齐参考稿：返回 + 下划线输入 + 清除 + 搜索） -->
  <view class="search-topbar" style="{{topbarStyle}}">
    <view class="topbar-row">
      <view class="btn-icon tap" bindtap="onBack" aria-label="返回">
        <view class="icon-back"></view>
      </view>
      <view class="search-field">
        <input
          class="search-underline-input"
          value="{{keyword}}"
          placeholder="年代 / 人物 / 事件"
          placeholder-class="search-placeholder"
          bindinput="onInput"
          confirm-type="search"
          bindconfirm="onConfirm"
        />
        <view
          wx:if="{{keyword}}"
          class="btn-clear tap"
          catchtap="onClear"
          aria-label="清除"
        >
          <view class="icon-close"></view>
        </view>
      </view>
      <view class="btn-icon tap" bindtap="onConfirm" aria-label="搜索">
        <view class="icon-search"></view>
      </view>
    </view>
  </view>

  <scroll-view
    class="body-scroll"
    scroll-y
    enhanced
    show-scrollbar="{{false}}"
  >
    <view class="section" wx:if="{{hotKeywords.length}}">
      <view class="section-label">热门搜索</view>
      <view class="hot-row">
        <view
          wx:for="{{hotKeywords}}"
          wx:key="keyword"
          class="hot-item {{item.isHot ? 'hot-item--pill' : 'hot-item--plain'}}"
          bindtap="tapKeyword"
          data-k="{{item.keyword}}"
        >
          {{item.keyword}}
        </view>
      </view>
    </view>

    <view class="section" wx:if="{{historyKeywords.length}}">
      <view class="section-label">历史记录</view>
      <view class="history-list">
        <view class="history-item" wx:for="{{historyKeywords}}" wx:key="keyword">
          <view class="history-keyword tap" bindtap="tapKeyword" data-k="{{item.keyword}}">
            {{item.keyword}}
          </view>
          <view
            class="history-del tap"
            catchtap="removeHistory"
            data-k="{{item.keyword}}"
            aria-label="删除"
          >
            <text class="history-del-icon">×</text>
          </view>
        </view>
      </view>
    </view>

    <view
      wx:if="{{!hotKeywords.length && !historyKeywords.length}}"
      class="hint-empty"
    >
      输入关键词搜索朝代、人物与史略
    </view>
  </scroll-view>
</view>
