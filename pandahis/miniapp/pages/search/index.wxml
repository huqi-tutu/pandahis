<view class="page-search">
  <proto-nav title="搜索" show-back="{{false}}"></proto-nav>

  <view class="search-body" style="padding-top: {{headerPadPx}}px;">

    <!-- 搜索框 -->
    <view class="search-bar-wrap">
      <view class="search-bar">
        <text class="search-ico">⌕</text>
        <input
          class="search-input"
          placeholder="年代 / 人物 / 事件"
          placeholder-class="search-placeholder"
          confirm-type="search"
          bindconfirm="onConfirm"
          bindinput="onInput"
          value="{{keyword}}"
        />
        <text wx:if="{{keyword}}" class="search-clear" catchtap="onClear">✕</text>
      </view>
    </view>

    <!-- 热门搜索 -->
    <view class="search-section" wx:if="{{hotKeywords.length}}">
      <text class="search-section-title">热门搜索</text>
      <view class="search-tags">
        <view
          wx:for="{{hotKeywords}}"
          wx:key="keyword"
          class="search-tag {{item.isHot ? 'search-tag--hot' : ''}}"
          bindtap="tapKeyword"
          data-k="{{item.keyword}}"
        >{{item.keyword}}</view>
      </view>
    </view>

    <!-- 历史记录 -->
    <view class="search-section" wx:if="{{historyKeywords.length}}">
      <text class="search-section-title">历史记录</text>
      <view class="search-history">
        <view
          wx:for="{{historyKeywords}}"
          wx:key="keyword"
          class="search-history-item"
        >
          <text
            class="search-history-text"
            bindtap="tapKeyword"
            data-k="{{item.keyword}}"
          >{{item.keyword}}</text>
          <text
            class="search-history-del"
            catchtap="removeHistory"
            data-k="{{item.keyword}}"
          >✕</text>
        </view>
      </view>
    </view>

    <!-- 空态 -->
    <view
      wx:if="{{!hotKeywords.length && !historyKeywords.length}}"
      class="search-empty"
    >输入关键词搜索朝代、人物与史略</view>

  </view>
</view>
