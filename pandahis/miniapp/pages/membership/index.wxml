<view class="page-shell">
  <proto-nav title="会员中心" show-back="{{false}}"></proto-nav>

  <view class="vip-hub-body" style="padding-top: {{headerPadPx}}px;">
    <text class="vip-hub-lead">选择适合你的典藏会员方案。会员有效期内评述、见证、原文免扣阅读点；未开通时可邀友助力或付费订阅。</text>

    <view class="vip-plans">
      <view
        wx:for="{{plans}}"
        wx:key="id"
        class="vip-plan {{item.kind === 'invite' ? 'vip-plan--invite' : ''}} {{selectedId === item.id ? 'selected' : ''}}"
        data-id="{{item.id}}"
        bindtap="onSelectPlan"
      >
        <view wx:if="{{item.tag}}" class="vip-plan-tag">{{item.tag}}</view>
        <view class="vip-plan-body">
          <text class="vip-plan-type">{{item.name}}</text>
          <text class="vip-plan-way">{{item.subtitle}}</text>
          <view class="vip-plan-price-wrap">
            <text class="vip-plan-price {{item.kind === 'invite' ? 'vip-plan-price--zero' : ''}}">¥{{item.priceYuan}}</text>
          </view>
        </view>
      </view>
    </view>

    <view class="vip-benefits">
      <text class="vip-benefits-title">高级权限包含</text>
      <view class="vip-benefit" wx:for="{{benefits}}" wx:key="*this">
        <text class="vip-benefit-icon">✦</text>
        <text class="vip-benefit-text">{{item}}</text>
      </view>
    </view>
  </view>

  <view class="vip-buy-bar {{isTabPage ? 'vip-buy-bar--tab' : ''}}">
    <view class="vip-buy-meta">
      <text class="vip-buy-meta-label">当前选择</text>
      <text class="vip-buy-meta-value">{{checkoutLine}}</text>
    </view>
    <view class="vip-buy-btn" bindtap="onConfirm">确认开通</view>
  </view>
</view>
